# Cloudflare Workers Static Assets custom response headers
# Long cache for immutable, fingerprinted static assets. All post images/media
# are now hashed assets under /_astro/* (a content change yields a new hash);
# fonts are stable. HTML is intentionally NOT cached long-term here.

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable
