---
/**
 * <Video> — a native HTML5 video player.
 *
 * Emits `<figure class="video-card relative"><video …></figure>`. The mp4
 * and its poster are imported through the build (hashed /_astro URLs) so no
 * raw /content/media or /content/images literal ships. Controls + metadata
 * preload + playsinline are set; the native player is intentionally kept
 * (no custom JS).
 *
 * `poster` accepts an images-tree path (optimized via the image pipeline) or a
 * media-tree thumbnail path; either resolves to a built asset URL.
 */
import { resolveVideo, resolveMediaPoster, tryMediaPoster } from './media';
import { resolveImage } from './images';

interface Props {
  /** Media-tree path ("2023/03/x.mp4") or legacy "/content/media/…". */
  src: string;
  /** Poster path: images-tree, media-tree, or their legacy "/content/…" forms. */
  poster?: string;
  /** Accessible label (used as aria-label on the player). */
  title?: string;
  /**
   * GIF-like playback: muted, looping, inline autoplay with no controls. Used
   * for short silent clips converted from animated GIFs so they keep the
   * original auto-playing look while shipping as a far smaller MP4.
   */
  autoplay?: boolean;
}

const { src, poster, title, autoplay = false } = Astro.props;

const videoUrl = resolveVideo(src);

// Posters live either as a sibling thumbnail in the media tree or as an
// image-tree asset. Try media first (sibling thumbnails are common), then fall
// back to the optimized image pipeline. An explicit "content/media" path forces
// the media tree.
let posterUrl: string | undefined;
if (poster) {
  if (/\/?content\/media\//.test(poster)) {
    posterUrl = resolveMediaPoster(poster);
  } else {
    posterUrl = tryMediaPoster(poster) ?? resolveImage(poster).src;
  }
}
---
<figure class="video-card relative">
  <video
    src={videoUrl}
    poster={posterUrl}
    controls={!autoplay}
    autoplay={autoplay}
    loop={autoplay}
    muted={autoplay}
    preload="metadata"
    playsinline
    aria-label={title}
    class="block h-auto w-full max-w-full"></video>
</figure>
