---
/**
 * SiteHeader.astro — the `#gh-head` header, rendered on every page
 * except home (which uses the Cover component instead).
 *
 * Navigation menus are empty (SITE.navigation = []) so only the logo
 * shows. The empty <nav class="gh-head-menu"> and <div class="gh-head-actions">
 * are kept because the CSS grid layout depends on them being present.
 * Site search is not implemented.
 */
import { SITE } from '../config';
---
<header id="gh-head" class="gh-head gh-outer">
  <div class="gh-head-inner gh-inner">
    <div class="gh-head-brand">
      <div class="gh-head-brand-wrapper">
        <a class="gh-head-logo" href={`${SITE.url}/`}>
          {/* Single logo image. */}
          <img src={SITE.logo} alt={SITE.title} />
        </a>
      </div>
    </div>

    <nav class="gh-head-menu"></nav>

    <div class="gh-head-actions"></div>
  </div>
</header>
