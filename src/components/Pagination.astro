---
/**
 * Pagination.astro — the feed pager.
 *
 * Renders a "Load more" link to the next page when one exists; omitted
 * when there is no next page. Functions as a plain `<a>` — no JavaScript
 * required.
 */
interface Props {
  /** Absolute or root-relative URL of the next page, if any. */
  nextUrl?: string;
}
const { nextUrl } = Astro.props;
---
{nextUrl ? (
  <nav class="load-more">
    <a href={nextUrl} class="button button-secondary gh-loadmore">Load more</a>
  </nav>
) : null}
