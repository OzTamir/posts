---
/**
 * Cover.astro — the home-page hero.
 * Renders the site icon + the site description inside a <code> element
 * (the description is "# cat /dev/brain >> posts").
 */
import { SITE } from '../config';
---
<div class="cover gh-outer">
  <div class="cover-content gh-inner">
    {SITE.icon && (
      <div class="cover-icon">
        <img class="cover-icon-image" src={SITE.icon} alt={SITE.title} />
      </div>
    )}

    {SITE.description && (
      <div class="cover-description">
        <code>{SITE.description}</code>
      </div>
    )}
  </div>
</div>
