---
/**
 * AuthorCard.astro — the author-archive header (ported from author.hbs).
 * Shows the author avatar, name (linked to their website), location meta,
 * bio, and the Facebook / Twitter / LinkedIn share links.
 *
 * The avatar uses Ghost's `size="xs"` derivative (w150) to match the live
 * markup's `/content/images/size/w150/...` src.
 */
import type { Author } from '../data/authors';
import Facebook from './icons/Facebook.astro';
import Twitter from './icons/Twitter.astro';
import Linkedin from './icons/Linkedin.astro';

interface Props {
  author: Author;
}
const { author } = Astro.props;

// Avatar — original path. Ghost's `size/w150` derivative is not shipped
// in the static export, so we reference the original (CSS sizes it).
const avatar = author.profileImage;
---
<section class="author gh-canvas">
  <div class="author-image-placeholder u-placeholder square">
    <img class="author-image u-object-fit" src={avatar} alt={author.name} />
  </div>

  {author.website ? (
    <h1 class="author-name">
      <a href={author.website} target="_blank" rel="noopener noreferrer">{author.name}</a>
    </h1>
  ) : (
    <h1 class="author-name">{author.name}</h1>
  )}

  {author.location && <span class="author-meta">{author.location}</span>}

  <div class="author-bio">{author.bio}</div>

  <div class="share author-social">
    {author.facebook && (
      <a class="share-link share-link-facebook author-social-item" href={`https://www.facebook.com/${author.facebook}`} target="_blank" rel="noopener noreferrer">
        <Facebook />
        Facebook
      </a>
    )}
    {author.twitter && (
      <a class="share-link share-link-twitter author-social-item" href={`https://x.com/${author.twitter.replace(/^@/, '')}`} target="_blank" rel="noopener noreferrer">
        <Twitter />
        Twitter
      </a>
    )}
    <a class="share-link share-link-linkedin author-social-item" href="https://www.linkedin.com/in/oz-tamir-7179b185" target="_blank" rel="noopener noreferrer">
      <Linkedin />
      LinkedIn
    </a>
  </div>
</section>
