---
/**
 * Tag archive page 1 — /tag/<slug>/ (generated for every tag with ≥1 post).
 * Ports tag.hbs: a `.tag` section with the tag NAME as <h1 class="tag-name">
 * (the CSS prepends a "#"), followed by the post-feed + pager.
 * Structure + body class match live-tag-technical.html
 * ("tag-template tag-<slug>").
 *
 * Title format: "<TagName> - 0xZ"; og:type=website; twitter card=summary.
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getSortedPosts, filterByTag } from '../../../utils/posts';
import { getAllTags } from '../../../utils/tags';
import { SITE } from '../../../config';

export const getStaticPaths = (async () => {
  const all = await getSortedPosts();
  const tags = getAllTags(all);
  const perPage = SITE.postsPerPage;

  return tags.map((tag) => {
    const posts = filterByTag(all, tag.slug);
    const totalPages = Math.max(1, Math.ceil(posts.length / perPage));
    return {
      params: { tag: tag.slug },
      props: {
        tag,
        pagePosts: posts.slice(0, perPage),
        totalPages,
      },
    };
  });
}) satisfies GetStaticPaths;

const { tag, pagePosts, totalPages } = Astro.props;

const canonical = `${SITE.url}/tag/${tag.slug}/`;
const nextUrl = totalPages > 1 ? `/tag/${tag.slug}/page/2/` : undefined;
const title = `${tag.name} - ${SITE.title}`;

const head = {
  type: 'tag',
  title,
  description: SITE.metaDescription,
  canonical,
  next: nextUrl ? `${SITE.url}${nextUrl}` : undefined,
  ogType: 'website',
  twitterCard: 'summary',
  primaryTag: tag.name,
};
---
<BaseLayout head={head} bodyClass={`tag-template tag-${tag.slug}`} isHome={false}>
  <div class="site-content">
    <main class="site-main">
      <section class="tag">
        <div class="gh-canvas">
          <h1 class="tag-name">{tag.name}</h1>
        </div>
      </section>
    </main>
  </div>

  <div class="post-feed gh-feed gh-canvas">
    {pagePosts.map(({ post, readingTime }) => (
      <PostCard post={post} readingTime={readingTime} />
    ))}
  </div>

  <Pagination nextUrl={nextUrl} />
</BaseLayout>
