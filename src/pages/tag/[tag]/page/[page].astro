---
/**
 * Tag archive pagination — /tag/<slug>/page/N/ for pages 2..N only
 * (page 1 is tag/[tag]/index.astro; /page/1/ is not emitted).
 *
 * The tag name heading appears on every paginated page.
 * Body class = "tag-template tag-<slug> paged".
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostFeed from '../../../../components/PostFeed';
import Pagination from '../../../../components/Pagination';
import { getSortedPosts, filterByTag, paginatePosts, pageCount, toPostCardData } from '../../../../utils/posts';
import { getAllTags } from '../../../../utils/tags';
import { SITE } from '../../../../config';

export const getStaticPaths = (async () => {
  const all = await getSortedPosts();
  const paths = [];
  for (const tag of getAllTags(all)) {
    const totalPages = pageCount(filterByTag(all, tag.slug).length, SITE.postsPerPage);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({ params: { tag: tag.slug, page: String(page) }, props: { tag, page } });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { tag, page } = Astro.props;
const all = await getSortedPosts();
const posts = filterByTag(all, tag.slug);
const { pagePosts, nextUrl, prevUrl } = paginatePosts(posts, page, SITE.postsPerPage, `/tag/${tag.slug}`);

const canonical = `${SITE.url}/tag/${tag.slug}/page/${page}/`;
const title = `${tag.name} - ${SITE.title}`;

const head = {
  type: 'tag',
  title,
  description: SITE.metaDescription,
  canonical,
  next: nextUrl ? `${SITE.url}${nextUrl}` : undefined,
  prev: prevUrl ? `${SITE.url}${prevUrl}` : undefined,
  ogType: 'website',
  twitterCard: 'summary',
  primaryTag: tag.name,
};
---
<BaseLayout head={head} bodyClass={`tag-template tag-${tag.slug} paged`} isHome={false}>
  <div class="site-content">
    <main class="site-main">
      <section class="tag">
        <div class="gh-canvas">
          <h1 class="tag-name">{tag.name}</h1>
        </div>
      </section>
    </main>
  </div>

  <PostFeed posts={pagePosts.map(toPostCardData)} />

  <Pagination nextUrl={nextUrl} />
</BaseLayout>
