---
/**
 * Home page (page 1) — cover hero + the feed (newest `postsPerPage` posts,
 * with in-place "Load more") inside <div class="home-content">.
 * The header is absent (home uses the Cover component instead).
 * Body class = "home-template".
 *
 * Thin Astro shell: loads content + builds the <head> props, then renders the
 * React components (Cover / Feed) inside BaseLayout. The Feed island is given
 * the whole post list and reveals more on demand; the static /page/N/ routes
 * remain the no-JS / crawler fallback.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Cover from '../components/Cover';
import Feed from '../components/Feed';
import { getSortedPosts, paginatePosts, toPostCardData } from '../utils/posts';
import { socialImageUrl } from '../utils/images';
import { SITE } from '../config';

const all = await getSortedPosts();
const { nextUrl } = paginatePosts(all, 1, SITE.postsPerPage, '');

// Home social images become optimized /_astro assets (absolute URLs). The OG
// art (og-default) has transparent corners, so keep it PNG. The Twitter card
// shares that same image — the bare square logo looked wrong on a large card.
const ogImg = await socialImageUrl(SITE.url, SITE.ogImage, 'png');
const twImg = ogImg;

const head = {
  type: 'home',
  title: SITE.metaTitle, // <title> = "0xZ | Posts"
  description: SITE.metaDescription,
  // Home OG/Twitter titles.
  ogTitle: SITE.ogTitle, // "Read posts from 0xZ"
  ogDescription: SITE.ogDescription,
  twitterTitle: SITE.twitterTitle, // "Read posts from 0xZ"
  twitterDescription: SITE.twitterDescription,
  canonical: `${SITE.url}/`,
  next: nextUrl ? `${SITE.url}${nextUrl}` : undefined,
  ogType: 'website',
  ogImage: ogImg?.url,
  twitterImage: twImg?.url,
};
---
<BaseLayout head={head} bodyClass="home-template" isHome={true}>
  <div class="home-content">
    <Cover />

    <Feed client:visible posts={all.map(toPostCardData)} perPage={SITE.postsPerPage} nextHref={nextUrl} />
  </div>
</BaseLayout>
