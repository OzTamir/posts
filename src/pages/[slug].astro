---
/**
 * Single post — /<slug>/ (param = post.id = the filename stem).
 * Renders the Markdown body through the React PostLayout and builds the
 * per-post <head> (canonical, Open Graph, Twitter card, JSON-LD Article).
 *
 * Markdown rendering: `render(post)` yields the Astro <Content /> component.
 * The MDX component kit (Figure/Video/Tweet/Instagram) is forwarded via its
 * `components` prop, so posts use those tags WITHOUT per-file import lines.
 * <Content /> is passed as the default slot to the React <PostLayout>, which
 * Astro forwards as that component's `children`. PostLayout stays static. A tiny
 * inline embed-loader script (Twitter / Instagram widgets) is mounted in
 * BaseLayout's `after` slot alongside the dormant PhotoSwipe lightbox markup;
 * it injects the widget scripts only when the body contains the embeds, so
 * the page itself ships no JS bundle.
 *
 * SEO precedence (per-post overrides → sensible defaults):
 *   title        = metaTitle  ?? title
 *   description  = metaDescription ?? excerpt
 *   og:title     = ogTitle    ?? title
 *   og:image     = ogImage    ?? featureImage   (absolute path)
 *   twitter:img  = twitterImage ?? featureImage  (absolute path)
 *   canonical    = canonicalUrl ?? <site>/<slug>/
 */
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostLayout from '../layouts/PostLayout';
import { getSortedPosts, getRelated } from '../utils/posts';
import { optimizeFeatureImage, socialImageUrl } from '../utils/images';
import { AUTHORS, DEFAULT_AUTHOR } from '../data/authors';
import { SITE } from '../config';
// The MDX component kit, auto-registered for every post via the <Content>
// `components` prop below — so posts use bare <Figure>/<Video>/<Tweet>/
// <Instagram> with no per-file import lines.
import Figure from '../components/mdx/Figure.astro';
import Video from '../components/mdx/Video.astro';
import Tweet from '../components/mdx/Tweet.astro';
import Instagram from '../components/mdx/Instagram.astro';

const mdxComponents = { Figure, Video, Tweet, Instagram };

export const getStaticPaths = (async () => {
  const all = await getSortedPosts();
  return all.map(({ post, readingTime }) => ({
    params: { slug: post.id },
    props: {
      post,
      readingTime,
      related: getRelated(all, post, 5),
    },
  }));
}) satisfies GetStaticPaths;

const { post, readingTime, related } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const author = AUTHORS[d.author] ?? DEFAULT_AUTHOR;
const primaryTag = d.tags?.[0];

const canonical = d.canonicalUrl ?? `${SITE.url}/${post.id}/`;

const description = d.metaDescription ?? d.excerpt ?? undefined;

// In-page feature image → optimized (WebP + srcset; GIF preserved). Passed to
// the React PostLayout as plain attributes so the tree stays static.
const feature = await optimizeFeatureImage(d.featureImage);

// og:image / twitter:image — single optimized absolute URL for scrapers.
const ogSocial = await socialImageUrl(SITE.url, d.ogImage ?? d.featureImage);
const twSocial = await socialImageUrl(SITE.url, d.twitterImage ?? d.featureImage);

// Body template class: "post-template tag-<primaryTag>".
const bodyClass = `post-template ${primaryTag ? `tag-${primaryTag.slug}` : ''}`.trim();

const head = {
  type: 'post',
  title: d.metaTitle ?? d.title, // <title> = post title (no site suffix)
  description,
  ogTitle: d.ogTitle ?? d.title,
  ogDescription: d.ogDescription ?? description,
  twitterTitle: d.twitterTitle ?? d.title,
  twitterDescription: d.twitterDescription ?? description,
  canonical,
  ogImage: ogSocial?.url,
  twitterImage: twSocial?.url,
  ogImageWidth: ogSocial?.width || undefined,
  ogImageHeight: ogSocial?.height || undefined,
  publishedTime: d.pubDate.toISOString(),
  modifiedTime: (d.updatedDate ?? d.pubDate).toISOString(),
  primaryTag: primaryTag?.name,
  authorName: author.name,
  authorSlug: author.slug,
};
---
<BaseLayout head={head} bodyClass={bodyClass} isPost={true}>
  <PostLayout post={post} readingTime={readingTime} related={related} feature={feature}>
    <Content components={mdxComponents} />
  </PostLayout>

  {/* PhotoSwipe lightbox container — dormant markup (no lightbox JS ships),
      kept 1:1 for parity. Rendered as a sibling of .site. */}
  <div slot="after" class="pswp" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="pswp__bg"></div>
    <div class="pswp__scroll-wrap">
      <div class="pswp__container">
        <div class="pswp__item"></div>
        <div class="pswp__item"></div>
        <div class="pswp__item"></div>
      </div>
      <div class="pswp__ui pswp__ui--hidden">
        <div class="pswp__top-bar">
          <div class="pswp__counter"></div>
          <button class="pswp__button pswp__button--close" title="Close (Esc)"></button>
          <button class="pswp__button pswp__button--share" title="Share"></button>
          <button class="pswp__button pswp__button--fs" title="Toggle fullscreen"></button>
          <button class="pswp__button pswp__button--zoom" title="Zoom in/out"></button>
          <div class="pswp__preloader">
            <div class="pswp__preloader__icn">
              <div class="pswp__preloader__cut">
                <div class="pswp__preloader__donut"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
          <div class="pswp__share-tooltip"></div>
        </div>
        <button class="pswp__button pswp__button--arrow--left" title="Previous (arrow left)"></button>
        <button class="pswp__button pswp__button--arrow--right" title="Next (arrow right)"></button>
        <div class="pswp__caption">
          <div class="pswp__caption__center"></div>
        </div>
      </div>
    </div>
  </div>

  {/* Social-embed loader — injects widgets.js / embed.js only when the post
      body contains .twitter-tweet / .instagram-media. Tiny inline script, so
      the page ships no JS bundle. */}
  <script slot="after" is:inline>
    (function () {
      if (document.querySelector('.twitter-tweet')) {
        var s = document.createElement('script');
        s.src = 'https://platform.twitter.com/widgets.js';
        s.async = true;
        s.setAttribute('charset', 'utf-8');
        document.body.appendChild(s);
      }
      if (document.querySelector('.instagram-media')) {
        var i = document.createElement('script');
        i.src = 'https://www.instagram.com/embed.js';
        i.async = true;
        document.body.appendChild(i);
      }
    })();
  </script>
</BaseLayout>
