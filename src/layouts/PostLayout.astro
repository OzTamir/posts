---
/**
 * PostLayout.astro — the single-post scaffold (ports post.hbs +
 * partials/content.hbs + single-footer.hbs + pswp.hbs).
 *
 * Structure (matches live-post-hello-world.html):
 *   <main class="site-main">
 *     <article class="single post tag-…">
 *       <header class="single-header gh-canvas"> meta · title · excerpt · feature image </header>
 *       <div class="single-content gh-content gh-canvas"> {content} + FIN divider </div>
 *     </article>
 *     <RelatedPosts/>            (related-wrapper)
 *     <div class="gh-canvas"><footer class="single-footer"> author bio </footer></div>
 *   </main>
 *   <PSWP markup>
 *
 * After the content, embed loader scripts are injected only when the
 * rendered HTML actually contains the relevant embeds:
 *   .twitter-tweet   → https://platform.twitter.com/widgets.js
 *   .instagram-media → https://www.instagram.com/embed.js
 */
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { AUTHORS, DEFAULT_AUTHOR } from '../data/authors';
import { formatPostDate, dateAttr } from '../utils/format';

interface RelatedItem {
  post: CollectionEntry<'posts'>;
  readingTime: number;
}
interface Props {
  post: CollectionEntry<'posts'>;
  readingTime: number;
  related: RelatedItem[];
  head: Record<string, unknown>;
}
const { post, readingTime, related, head } = Astro.props;
const d = post.data;

const author = AUTHORS[d.author] ?? DEFAULT_AUTHOR;
const primaryTag = d.tags?.[0];

// Ghost post_class → "post tag-<slug> …" used on <article> and <body>.
const tagClasses = (d.tags ?? []).map((t) => `tag-${t.slug}`).join(' ');
const bodyClass = `post-template ${primaryTag ? `tag-${primaryTag.slug}` : ''}`.trim();

// Feature image. NOTE: Ghost's `size/wXXX/` derivatives are NOT shipped in
// the static export (only originals live under /content/images/**), so we
// reference the ORIGINAL path. The CSS (.single-media + u-placeholder)
// controls sizing, so the rendered result matches the live layout.
const featureImage = d.featureImage ?? null;
const featureAlt = d.featureImageAlt || d.title;

// Author avatar — original path (the w150 derivative is not shipped).
const authorAvatar = author.profileImage;
---
<BaseLayout head={head} bodyClass={bodyClass} isPost={true}>
  <div class="site-content">
    <main class="site-main">
      <article class={`single post ${tagClasses}`.trim()}>
        <header class="single-header gh-canvas">
          <div class="single-meta">
            <span class="single-meta-item single-meta-date">
              <time datetime={dateAttr(d.pubDate)}>
                {formatPostDate(d.pubDate)}
              </time>
            </span>
            <span class="single-meta-item single-meta-length">
              {readingTime} min read
            </span>
            {primaryTag && (
              <span class="single-meta-item single-meta-tag">
                <a class={`post-tag post-tag-${primaryTag.slug}`} href={`/tag/${primaryTag.slug}/`}>
                  {primaryTag.name}
                </a>
              </span>
            )}
          </div>

          <h1 class="single-title">{d.title}</h1>

          {d.excerpt && (
            <div class="single-excerpt">
              {d.excerpt}
            </div>
          )}

          {featureImage && (
            <figure class="single-media kg-width-wide">
              <div class="u-placeholder horizontal">
                <img
                  class="u-object-fit"
                  sizes="(min-width: 1200px) 920px, 92vw"
                  src={featureImage}
                  alt={featureAlt}
                />
              </div>
              {d.featureImageCaption && <figcaption set:html={d.featureImageCaption} />}
            </figure>
          )}
        </header>

        <div class="single-content gh-content gh-canvas">
          <slot />
          {/* End-of-post "FIN" divider — emitted by Dawn's content wrapper. */}
          <div style="margin-top: 3rem; display: flex; align-items: center; justify-content: center; gap: 1rem;">
            <span style="flex: 1; max-width: 100px; height: 1px; background-color: var(--light-gray-color);"></span>
            <code>FIN</code>
            <span style="flex: 1; max-width: 100px; height: 1px; background-color: var(--light-gray-color);"></span>
          </div>
        </div>
      </article>

      <RelatedPosts related={related} />

      <div class="gh-canvas">
        <footer class="single-footer">
          <div class="single-footer-author">
            <div class="author-image-column">
              <div class="author-image-placeholder u-placeholder square">
                <a href={`/author/${author.slug}/`} title={author.name}>
                  <img
                    class="author-image u-object-fit"
                    src={authorAvatar}
                    alt={author.name}
                    loading="lazy"
                  />
                </a>
              </div>
            </div>
            <div class="author-content-column">
              <h3 class="single-footer-title">About Me</h3>
              <div class="author-bio">
                {author.bio}
              </div>
            </div>
          </div>
        </footer>
      </div>
    </main>
  </div>

  {/* PhotoSwipe lightbox container (parity with the live theme markup),
      rendered as a sibling of .site exactly like Ghost's default.hbs. */}
  <div slot="after" class="pswp" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="pswp__bg"></div>
    <div class="pswp__scroll-wrap">
      <div class="pswp__container">
        <div class="pswp__item"></div>
        <div class="pswp__item"></div>
        <div class="pswp__item"></div>
      </div>
      <div class="pswp__ui pswp__ui--hidden">
        <div class="pswp__top-bar">
          <div class="pswp__counter"></div>
          <button class="pswp__button pswp__button--close" title="Close (Esc)"></button>
          <button class="pswp__button pswp__button--share" title="Share"></button>
          <button class="pswp__button pswp__button--fs" title="Toggle fullscreen"></button>
          <button class="pswp__button pswp__button--zoom" title="Zoom in/out"></button>
          <div class="pswp__preloader">
            <div class="pswp__preloader__icn">
              <div class="pswp__preloader__cut">
                <div class="pswp__preloader__donut"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
          <div class="pswp__share-tooltip"></div>
        </div>
        <button class="pswp__button pswp__button--arrow--left" title="Previous (arrow left)"></button>
        <button class="pswp__button pswp__button--arrow--right" title="Next (arrow right)"></button>
        <div class="pswp__caption">
          <div class="pswp__caption__center"></div>
        </div>
      </div>
    </div>
  </div>

  {/* Conditionally load social-embed scripts only when the post needs them. */}
  <script slot="after" is:inline>
    (function () {
      if (document.querySelector('.twitter-tweet')) {
        var s = document.createElement('script');
        s.src = 'https://platform.twitter.com/widgets.js';
        s.async = true;
        s.charset = 'utf-8';
        document.body.appendChild(s);
      }
      if (document.querySelector('.instagram-media')) {
        var i = document.createElement('script');
        i.src = 'https://www.instagram.com/embed.js';
        i.async = true;
        document.body.appendChild(i);
      }
    })();
  </script>
</BaseLayout>
