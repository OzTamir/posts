---
/**
 * BaseLayout.astro — the thin html/head/body shell shared by every route.
 *
 * This stays a (thin) .astro shell because it owns inherently Astro-level
 * concerns: the <html>/<head> document and the inline theme script (which
 * must run before paint to avoid a flash of the wrong theme). Everything
 * visual is authored in React and rendered to static HTML (zero client JS):
 *   • <Head />        — React, un-hydrated (static <head>)
 *   • <SiteHeader />  — React, static (hidden on home)
 *   • <SiteFooter />  — React, static (includes the theme-toggle button markup)
 *   • page content    — React, via the default <slot />
 *
 * Theme resolution: the site has NO forced default — it follows the visitor's
 * OS prefers-color-scheme. A persisted choice (localStorage['theme']) always
 * wins. The inline head script runs before first paint (no flash): it applies
 * theme-dark/theme-light from localStorage if set, otherwise from the system
 * preference. The footer toggle flips the class + persists the choice; once
 * persisted it wins on every return visit. A prefers-color-scheme listener
 * only applies while no choice is stored. The only behaviour is these tiny
 * inline scripts, so the site ships no JS bundle.
 */
import Head from '../components/Head';
import SiteHeader from '../components/SiteHeader';
import SiteFooter from '../components/SiteFooter';
import { SITE } from '../config';
import '../styles/global.css';

interface Props {
  /** Props forwarded to the React Head component. */
  head: Record<string, unknown>;
  /** Space-separated body template classes, e.g. "post-template tag-thoughts". */
  bodyClass: string;
  /** Whether this is the home template (home hides the header + uses cover). */
  isHome?: boolean;
  /** Render the footer divider (single posts only). */
  isPost?: boolean;
}
const { head, bodyClass, isHome = false, isPost = false } = Astro.props;
---
<!DOCTYPE html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Head {...(head as any)} />
    {/* Resolve the theme before first paint (no flash): a persisted choice
        wins; otherwise follow the OS prefers-color-scheme. The explicit
        class is always set so the toggle icon/label + CSS stay consistent. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme =
            stored === 'light' || stored === 'dark'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          var html = document.documentElement;
          html.classList.remove('theme-dark', 'theme-light');
          html.classList.add(theme === 'dark' ? 'theme-dark' : 'theme-light');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={`${bodyClass} is-head-left-logo`}>
    <div class="site">
      {!isHome && <SiteHeader />}

      <slot />

      <SiteFooter isPost={isPost} />
    </div>

    {/* Sibling-of-.site content (e.g. the post route's embed-loader script),
        rendered after .site. */}
    <slot name="after" />

    {/* Theme toggle behaviour — flips .theme-dark / .theme-light on <html>,
        swaps the sun/moon icon + label, and PERSISTS only on an explicit click
        (so first-time visitors keep following the OS preference until they
        choose). A prefers-color-scheme listener updates the UI only while no
        choice is stored. Kept as a tiny inline script so the toggle ships no
        JS bundle. */}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        const themeToggle = document.getElementById('theme-toggle');
        const html = document.documentElement;

        const themeIcon = themeToggle ? themeToggle.querySelector('.gh-theme-icon') : null;
        const sunIcon = themeIcon ? themeIcon.innerHTML : '';
        const moonIcon =
          '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/></svg>';

        // Apply a theme to <html> + the toggle UI. `persist` is true only for
        // an explicit user click — first paint / system changes don't persist.
        function setTheme(theme, persist) {
          const themeText = document.getElementById('theme-text');
          html.classList.remove('theme-dark', 'theme-light');
          if (theme === 'dark') {
            html.classList.add('theme-dark');
            if (themeIcon) themeIcon.innerHTML = sunIcon;
            if (themeToggle) themeToggle.setAttribute('aria-label', 'Switch to light mode');
            if (themeText) themeText.textContent = 'Dark Mode';
          } else {
            html.classList.add('theme-light');
            if (themeIcon) themeIcon.innerHTML = moonIcon;
            if (themeToggle) themeToggle.setAttribute('aria-label', 'Switch to dark mode');
            if (themeText) themeText.textContent = 'Light Mode';
          }
          if (persist) localStorage.setItem('theme', theme);
        }

        // Sync the toggle icon/label to whatever the no-flash head script
        // already applied (localStorage choice or OS preference). Do NOT
        // persist here — that would freeze a first-time visitor's theme.
        const current = html.classList.contains('theme-light') ? 'light' : 'dark';
        setTheme(current, false);

        if (themeToggle) {
          themeToggle.addEventListener('click', function () {
            const newTheme = html.classList.contains('theme-dark') ? 'light' : 'dark';
            setTheme(newTheme, true);
          });
        }

        // Follow live OS changes only until the visitor makes a choice.
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
          if (!localStorage.getItem('theme')) setTheme(e.matches ? 'dark' : 'light', false);
        });
      });
    </script>
  </body>
</html>
