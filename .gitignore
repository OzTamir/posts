# dependencies
node_modules/

# build output
dist/
.astro/

# Lighthouse CI output
.lighthouseci/

# local scratch / QA artifacts (agent temp output, never committed)
scratchpad/

# cloudflare / wrangler
.wrangler/
.dev.vars

# env
.env
.env.*

# os / editor
.DS_Store
.DS_STORE
*.log

# local planning/design docs (kept on disk, not committed)
docs/superpowers/

# Vault CMS / Obsidian — per-user state (the vault lives in src/content/.obsidian;
# `**/` matches it wherever the vault is opened, unlike a root-anchored path).
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
.ref/

# Don't vendor third-party Obsidian plugin CODE (~6 MB of main.js/styles.css we
# don't maintain). Keep only the small per-plugin config — manifest.json (which
# plugin + version) and data.json (the VaultCMS wizard settings) — so the vault
# is documented and re-installable (`npx create-vaultcms`) without the bloat.
src/content/.obsidian/plugins/*/*
!src/content/.obsidian/plugins/*/manifest.json
!src/content/.obsidian/plugins/*/data.json
# …except claude-sidebar's data.json — it only holds machine-specific state
# (lastCwd, an absolute path), so it's per-user noise, not shared config.
src/content/.obsidian/plugins/claude-sidebar/data.json
